# PAIC environment configuration
# Copy this file to .env and fill in values before running docker compose up

# Master key for AES-GCM encryption of stored credentials.
# Generate a fresh key with: openssl rand -base64 32
PAIC_MASTER_KEY=

# Database URL for postgres-backed deployments.
# The default below matches the postgres service in docker-compose.yml.
PAIC_DATABASE_URL=postgresql+psycopg://paic:paic@postgres:5432/paic

# Postgres credentials (must match PAIC_DATABASE_URL above)
POSTGRES_USER=paic
POSTGRES_PASSWORD=paic
POSTGRES_DB=paic
