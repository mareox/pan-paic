# PAIC: environment overrides
# All values are optional; sensible defaults apply.

# Where YAML profile files are stored (mounted as a volume in compose).
PAIC_PROFILES_DIR=/app/profiles

# Bind address inside the container.
PAIC_BIND_HOST=0.0.0.0
PAIC_BIND_PORT=8080

# Log verbosity: DEBUG | INFO | WARNING | ERROR.
PAIC_LOG_LEVEL=INFO
